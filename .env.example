# ─────────────────────────────────────────────────────────────────
# CRM Cloud — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=crmuser
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=crmdb

# Backend
DATABASE_URL=postgresql://crmuser:your_strong_password_here@postgres:5432/crmdb
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRES=7d
CORS_ORIGIN=http://localhost
LOG_LEVEL=info

# Frontend (Vite build-time)
VITE_API_URL=/api

# Nginx
HTTP_PORT=80
HTTPS_PORT=443

# Production (AWS)
AWS_REGION=us-east-1
EC2_HOST=your-ec2-public-ip
EC2_USER=ubuntu
REGISTRY=ghcr.io/yourusername/crm-cloud
